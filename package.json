{
  "name": "echo-prodoc",
  "version": "0.1.0",
  "description": "ProDoc - 文档渲染与编辑框架",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "echo-prodoc": "./packages/prodoc-cli/dist/index.js"
  },
  "files": [
    "packages/*/dist/**",
    "packages/*/src/**",
    "packages/*/package.json",
    "packages/*/tsconfig.json",
    "packages/*/vite.config.ts",
    "scripts/"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:ui-frame": "node scripts/install-ui-frame.js",
    "type-check": "npm run type-check --workspaces",
    "clean": "npm run clean --workspaces",
    "view": "node ./packages/prodoc-cli/dist/index.js view",
    "edit": "node ./packages/prodoc-cli/dist/index.js edit",
    "postinstall": "node scripts/install-ui-frame.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@echolab/ui-frame": "github:EchoLab-Auto/ui-frame#cb443076fb6de8537c71399680482f3971d15363",
    "@prodoc/core": "file:packages/prodoc-core",
    "@prodoc/editor": "file:packages/prodoc-editor",
    "@prodoc/renderer": "file:packages/prodoc-renderer",
    "@vitejs/plugin-vue": "^6.0.7",
    "marked": "^18.0.5",
    "vue": "^3.5.35",
    "vue-tsc": "^2.2.12"
  }
}
