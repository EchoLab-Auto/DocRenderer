{
  "name": "prodoc",
  "version": "0.1.0",
  "description": "ProDoc - 文档渲染与编辑框架",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "echo-prodoc": "./packages/prodoc-cli/dist/index.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "build:ui-frame": "node scripts/install-ui-frame.js",
    "type-check": "npm run type-check --workspaces",
    "clean": "npm run clean --workspaces",
    "view": "node ./packages/prodoc-cli/dist/index.js view",
    "edit": "node ./packages/prodoc-cli/dist/index.js edit",
    "postinstall": "node scripts/install-ui-frame.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@echolab/ui-frame": "github:EchoLab-Auto/ui-frame#main",
    "@prodoc/core": "^0.1.0",
    "@prodoc/editor": "^0.1.0",
    "@prodoc/renderer": "^0.1.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vue": "^3.5.35",
    "vue-tsc": "^2.2.12"
  }
}
