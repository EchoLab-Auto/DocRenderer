{
  "name": "@prodoc/core",
  "version": "0.1.0",
  "description": "ProDoc 核心库 - 文档解析与数据模型",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@echolab/ui-frame": "github:EchoLab-Auto/ui-frame#39d9eb24f75ff0b3fe5bbcff73f552f21e38a9d4"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  }
}
